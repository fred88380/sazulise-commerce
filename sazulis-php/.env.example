# Sazulis Security Configuration
# Copier ce fichier en .env et remplacer les valeurs

# Application
APP_NAME=Sazulis Commerce
APP_URL=https://localhost/sazulis/sazulis-php
APP_BASE_PATH=/sazulis/sazulis-php

# Database (HTTPS ONLY)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sazulis_v2
DB_USER=root
DB_PASSWORD=secure_password_here

# Security
SECURITY_LEVEL=high
LOG_SECURITY_EVENTS=true
ENABLE_IP_VALIDATION=true
ENABLE_USER_AGENT_VALIDATION=true

# Session
SESSION_TIMEOUT=3600
SESSION_REGENERATE_INTERVAL=1800

# Rate Limiting
LOGIN_RATE_LIMIT=7
LOGIN_RATE_WINDOW=900
API_RATE_LIMIT=100
API_RATE_WINDOW=3600

# Email Verification (for phishing protection)
VERIFY_EMAIL_DOMAINS=true
ALLOWED_EMAIL_DOMAINS=gmail.com,outlook.com,yahoo.com,company.com

# Content Moderation
ENABLE_CONTENT_MODERATION=true
BLOCK_OFFENSIVE_CONTENT=true
BLOCK_RACIST_CONTENT=true
BLOCK_SEXUAL_CONTENT=true
LOG_MODERATION_EVENTS=true

# File Upload Security
MAX_UPLOAD_SIZE=5242880
ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf
SCAN_UPLOADS_FOR_MALWARE=false

# HTTPS/TLS
HTTPS_ONLY=true
HSTS_MAX_AGE=31536000

# Admin Email
ADMIN_EMAIL=sazulis@outlook.fr
ADMIN_EMAIL_VERIFIED=true

# API Keys (if used)
API_KEY_REQUIRED=false
API_RATE_LIMITING=true

# Logging
LOG_LEVEL=info
LOG_CHANNEL=file
LOG_PATH=logs/

# Disable dangerous PHP functions
DISABLE_FUNCTIONS=passthru,shell_exec,system,proc_open,popen,curl_exec,curl_multi_exec,parse_ini_file,show_source,exec,eval,assert,create_function,include,include_once,require,require_once
