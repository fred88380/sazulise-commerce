Options -Indexes

# Empêche l'accès web direct au fichier .env
<Files ".env">
    Order allow,deny
    Deny from all
</Files>

# Redirige les erreurs 404 et 410
ErrorDocument 404 /error404.php
ErrorDocument 410 /error410.php

RewriteEngine On

# 1. Force le HTTPS et supprime le WWW (redirection vers https://sazulis.fr)
RewriteCond %{HTTP_HOST} ^www\.sazulis\.fr [NC]
RewriteRule ^(.*)$ https://sazulis.fr/$1 [R=301,L]

RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://sazulis.fr/$1 [R=301,L]

# 2. Supprime l'extension .php visible dans la barre du navigateur (Redirection 301 pour le SEO)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^\ ]+)\.php\ HTTP/
RewriteRule ^(.*)\.php$ https://sazulis.fr/$1 [R=301,L]

# 3. Permet de lire en interne les fichiers .php même si l'URL ne l'affiche pas
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]